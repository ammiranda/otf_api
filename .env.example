# OrangeTheory Fitness API — Environment Configuration
#
# Required:
OTF_USERNAME=your@email.com          # Your OTF account email
OTF_PASSWORD=your-password           # Your OTF account password
OTF_CLIENT_ID=your-client-id         # Cognito app client ID (from OTF mobile app)

# Optional (defaults shown below — these rarely change):
# OTF_API_IO_BASE_URL=https://api.orangetheory.io/v1/         # Classes & bookings API
# OTF_API_CO_BASE_URL=https://api.orangetheory.co/mobile/v1/  # Studios API
# OTF_AUTH_URL=https://cognito-idp.us-east-1.amazonaws.com/   # Cognito auth
